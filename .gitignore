# Dependencies
node_modules/
.pnpm-store/

# Build artefacts
dist/
build/
.next/
.turbo/
.cache/
coverage/
*.tsbuildinfo

# Artefacts de compilation ad-hoc du test runner (vitest+swc résout les imports
# `./fixtures-loader.js` vers le source .ts — les .js/.d.ts/.js.map sont dead code)
apps/api/test/*.js
apps/api/test/*.d.ts
apps/api/test/*.js.map

# Runtime storage (zips archivés)
storage/

# Local databases
*.db
*.db-journal
*.sqlite
*.sqlite-journal
prisma/*.db

# Logs
*.log
logs/
.npm
.pnpm-debug.log*

# Env files
.env
.env.local
.env.*.local

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Claude Code local session artefacts
.claude/.events.log
.claude/.session-start-*

# Sensitive ECP backup files (clés privées / certificats / inventaire interne)
# Ne JAMAIS committer — voir design §11 et document fonctionnel §8bis.2
tests/fixtures/**/local_key_store.csv
tests/fixtures/**/registration_store.csv
tests/fixtures/**/registration_requests.csv

# Dumps ECP bruts : les zips contiennent les CSVs sensibles ci-dessus et ne
# peuvent pas être filtrés par pattern une fois empaquetés. On les ignore donc
# intégralement. Seuls les fichiers <EIC>-configuration.properties sont tolérés
# côté fixtures (pas de clés privées dans ce fichier), mais ils doivent être
# relus avant commit.
tests/fixtures/EXPORT/**/*.zip

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Smoke test zips générés localement pour upload manuel (non versionnés)
smoke-zips/
